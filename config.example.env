# Copy to .env and edit.
WCM_DATABASE_URL=sqlite:///./data/wx_content_mesh.db
WCM_OUTPUT_DIR=./outputs
WCM_UPLOAD_DIR=./uploads
WCM_SOURCE_REPO_DIR=/root/workspace/xueyu-gongzhonghao
WCM_ARTICLE_OUTBOX_DIR=/srv/self-media-exchange/outbox/wechat-article-files
WCM_VIDEO_OUTBOX_DIR=/srv/self-media-exchange/outbox/wechat-video-delivery
WCM_USE_STABLE_TOKEN=true
WCM_ALLOW_WECHAT_PREVIEW=false
WCM_ALLOW_WECHAT_PUBLISH=false
WCM_APP_BASE_URL=http://127.0.0.1:8000
WCM_RENDER_THEME=wemd_clean
# Optional LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
# Example account secret env var referenced by account.secret_env_name
WX_ACCOUNT_MAIN_SECRET=
